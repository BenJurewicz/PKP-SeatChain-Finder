{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "shadcn": {
            "type": "local",
            "command": [
                "npx",
                "shadcn@latest",
                "mcp"
            ],
            "enabled": true
        },
        "nextjs": {
            "type": "local",
            "command": [
                "npx",
                "-y",
                "next-devtools-mcp@latest"
            ],
            "enabled": true,
            "environment": {
                "NEXT_PROJECT_PATH": "."
            }
        }
    }
}
